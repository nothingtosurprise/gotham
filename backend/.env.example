# ─────────────────────────────────────────────
# GOTHAM INTELLIGENCE PLATFORM — ENV CONFIG
# ─────────────────────────────────────────────

PORT=3001

# OpenSky Network (free, no key needed for public)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# NASA APIs (get free key at https://api.nasa.gov)
NASA_API_KEY=DEMO_KEY

# USGS Earthquake Feed (free, no key needed)
# https://earthquake.usgs.gov/earthquakes/feed/v1.0/geojson.php
USGS_BASE_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary

# AbuseIPDB (free tier - https://www.abuseipdb.com/api)
ABUSEIPDB_KEY=

# Shodan (https://www.shodan.io - free tier)
SHODAN_KEY=

# Open-Meteo (free weather/environment, no key)
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# Celestrak TLE satellite data (free, no key)
CELESTRAK_BASE_URL=https://celestrak.org/SOCRATES/query.php

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
